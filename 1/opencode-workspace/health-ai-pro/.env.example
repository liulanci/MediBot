# 医智宝 (MediBot) 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ===========================================
# 数据库配置 | Database Configuration
# ===========================================

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_NAME=medibot

# ===========================================
# 服务器配置 | Server Configuration
# ===========================================

PORT=3000
NODE_ENV=development

# ===========================================
# AI 模型配置 | AI Model Configuration
# ===========================================

# OpenAI API (可选)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Claude API (可选)
CLAUDE_API_KEY=sk-ant-your-claude-api-key-here

# ===========================================
# 安全配置 | Security Configuration
# ===========================================

# 会话密钥
SESSION_SECRET=your-session-secret-here

# JWT 密钥
JWT_SECRET=your-jwt-secret-here

# ===========================================
# 第三方服务 | Third-party Services
# ===========================================

# 短信服务 (可选)
SMS_API_KEY=your-sms-api-key-here
SMS_TEMPLATE_ID=your-template-id-here

# 邮件服务 (可选)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password-here

# ===========================================
# 日志配置 | Logging Configuration
# ===========================================

LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ===========================================
# CDN 和存储 | CDN and Storage
# ===========================================

# 文件存储 (可选)
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# S3_BUCKET=your-bucket-name

# ===========================================
# 缓存配置 | Cache Configuration
# ===========================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here

# ===========================================
# 监控和统计 | Monitoring and Analytics
# ===========================================

# Google Analytics (可选)
GA_TRACKING_ID=UA-XXXXXXXXX-X

# Sentry 错误追踪 (可选)
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ===========================================
# 其他配置 | Other Configuration
# ===========================================

# 网站 URL
SITE_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# 时区
TZ=Asia/Shanghai

# 语言
LOCALE=zh-CN
